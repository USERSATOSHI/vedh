{
  "name": "vedh",
  "version": "0.1.0",
  "description": "A local code knowledge graph for developers and AI coding agents.",
  "license": "Apache-2.0",
  "author": "usersatoshi",
  "type": "module",
  "bin": {
    "vedh": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "bun run build:workspaces && bun run build:distribution",
    "build:workspaces": "bun run --filter '*' build",
    "build:distribution": "bun scripts/build-distribution.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run build && node --test packages/parser/dist/resolver/index.test.js packages/parser/dist/engine/index.test.js packages/core/dist/indexer/index.test.js packages/core/dist/analysis/louvain.test.js",
    "lint": "eslint packages --max-warnings=0",
    "lint:fix": "eslint packages --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usersatoshi/vedh.git"
  },
  "bugs": {
    "url": "https://github.com/usersatoshi/vedh/issues"
  },
  "homepage": "https://github.com/usersatoshi/vedh#readme",
  "workspaces": [
    "packages/*",
    "packages/extensions/*"
  ],
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2"
  }
}
